generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id                      Int                       @id @default(autoincrement())
  branch_name             String
  branch_code             String                    @unique
  address                 String?
  status                  Status                    @default(active)
  invoices                Invoice[]
  invoiceSettings         InvoiceSettings[]
  paymentOutSettings      PaymentOutSettings[]
  deliveryChallans        DeliveryChallan[]
  deliveryChallanSettings DeliveryChallanSettings[]
  proformaInvoices        ProformaInvoice[]
  proformaSettings        ProformaSettings[]
  purchaseInvoices        PurchaseInvoice[]
  purchaseSettings        PurchaseInvoiceSettings[]
  PurchaseOrder           PurchaseOrder[]
  quotations              Quotation[]
  quotationSettings       QuotationSettings[]
  users                   User[]
}

model User {
  id               Int           @id @default(autoincrement())
  name             String
  email            String?       @unique
  mobile           String?       @unique
  password_hash    String
  role             Role
  branch_code      String?
  isActive         Boolean       @default(true)
  status           Status        @default(active)
  created_at       DateTime      @default(now())
  createdAt        DateTime      @default(now())
  reset_otp        String?
  reset_otp_expiry DateTime?
  branch           Branch?       @relation(fields: [branch_code], references: [branch_code])
  sessions         UserSession[]
}

model UserSession {
  id         Int      @id @default(autoincrement())
  token      String
  last_login DateTime @default(now())
  device     String?
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Party {
  id                 Int                @id @default(autoincrement())
  name               String
  partyName          String
  mobileNumber       String?
  email              String?
  gstin              String?
  panNumber          String?
  partyType          PartyType
  partyCategory      String?
  billingAddress     String?
  shippingAddress    String?
  creditPeriod       Int?
  creditLimit        Decimal?           @db.Decimal(12, 2)
  openingBalance     Decimal?           @db.Decimal(12, 2)
  openingBalanceType BalanceType?
  status             Status             @default(active)
  createdAt          DateTime           @default(now())
  created_at         DateTime           @default(now())
  contactPersonName  String?
  dateOfBirth        String?
  invoices           Invoice[]
  addresses          PartyAddress[]
  bankAccounts       PartyBankAccount[]
  contacts           PartyContact[]
  customFields       PartyCustomField[]
  deliveryChallans   DeliveryChallan[]
  proformaInvoices   ProformaInvoice[]
  ledgerEntries      PartyLedger[]
  partyPrices        PartyWisePrice[]
  paymentsIn         PaymentIn[]
  paymentOuts        PaymentOut[]
  purchaseInvoices   PurchaseInvoice[]
  purchaseOrders     PurchaseOrder[]
  Quotation          Quotation[]
  salesReturns       SalesReturn[]
}

model Product {
  id                   Int                   @id @default(autoincrement())
  name                 String
  createdAt            DateTime              @default(now())
  category             String?
  enableSerial         Boolean               @default(false)
  gstRate              String?
  itemType             ItemType
  salesPrice           Decimal?              @db.Decimal(10, 2)
  serviceCode          String?
  showOnlineStore      Boolean               @default(false)
  status               Status                @default(active)
  unit                 String?
  description          String?
  hsnCode              String?
  itemCode             String?               @unique
  lowStockAlert        Boolean               @default(false)
  lowStockQty          Int?
  mrp                  Decimal?              @db.Decimal(10, 2)
  mrpEnabled           Boolean               @default(false)
  purchasePrice        Decimal?              @db.Decimal(10, 2)
  sacCode              String?
  salesDiscountPercent Float?
  trackBatchExpiry     Boolean               @default(false)
  wholesaleEnabled     Boolean               @default(false)
  wholesalePrice       Decimal?              @db.Decimal(10, 2)
taxType              String                @default("without_tax")
baseSalesPrice       Decimal?              @db.Decimal(10, 2)   // always the pre-tax price
salesPriceInclTax    Boolean               @default(false)      // was the entered price inclusive?
basePurchasePrice    Decimal?              @db.Decimal(10, 2)   // always the pre-tax purchase price
purchasePriceInclTax Boolean               @default(false)      // was the entered purchase price inclusive?
  deliveryChallanItems DeliveryChallanItem[]
  proformaInvoiceItems ProformaInvoiceItem[]

  invoiceItems         InvoiceItem[]
  partyPrices          PartyWisePrice[]
  ProductCustomField   ProductCustomField[]
  images               ProductImage[]
  ProductStock         ProductStock[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  PurchaseOrderItem    PurchaseOrderItem[]
  quotationItems       QuotationItem[]
  salesReturnItems     SalesReturnItem[]
  stockLedger          StockLedger[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Godown {
  godown_id            Int                   @id @default(autoincrement())
  godown_name          String
  street_address       String?
  state_name           String?
  city_name            String?
  pincode              String?
  created_at           DateTime              @default(now())
  InvoiceItem          InvoiceItem[]
  stocks               ProductStock[]
  deliveryChallanItems DeliveryChallanItem[]
  ProformaInvoiceItem  ProformaInvoiceItem[]
  PurchaseInvoiceItem  PurchaseInvoiceItem[]
  QuotationItem        QuotationItem[]
  stockLedger          StockLedger[]
  salesReturnItems   SalesReturnItem[]
}

model ProductStock {
  id           Int      @id @default(autoincrement())
  productId    Int
  godownId     Int
  openingStock Int
  asOfDate     DateTime
  createdAt    DateTime @default(now())
  currentStock Int      @default(0)
  godown       Godown   @relation(fields: [godownId], references: [godown_id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, godownId])
  @@index([productId])
  @@index([godownId])
}

model StockLedger {
  id          Int          @id @default(autoincrement())
  productId   Int
  godownId    Int?
  date        DateTime     @default(now())
  refType     StockRefType
  refId       Int?
  quantityIn  Int          @default(0)
  quantityOut Int          @default(0)
  balance     Int
  remarks     String?
  createdAt   DateTime     @default(now())
  godown      Godown?      @relation(fields: [godownId], references: [godown_id])
  product     Product      @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([date])
  @@index([productId, godownId])
}

model PartyWisePrice {
  id        Int     @id @default(autoincrement())
  productId Int
  partyId   Int
  price     Decimal @db.Decimal(10, 2)
  party     Party   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, partyId])
}

model ProductCustomField {
  id         Int      @id @default(autoincrement())
  productId  Int
  fieldName  String
  fieldValue String
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  imageUrl  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PartyLedger {
  id        Int           @id @default(autoincrement())
  partyId   Int
  date      DateTime      @default(now())
  createdAt DateTime      @default(now())
  refType   LedgerRefType
  refId     Int?
  reference String?
  type      LedgerType
  amount    Float?
  debit     Decimal?      @db.Decimal(12, 2)
  credit    Decimal?      @db.Decimal(12, 2)
  balance   Decimal       @db.Decimal(12, 2)
  party     Party         @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

model PaymentIn {
  id          Int                 @id @default(autoincrement())
  paymentNo   String              @unique
  partyId     Int
  date        DateTime
  mode        PaymentMode
  amount      Decimal             @db.Decimal(12, 2)
  notes       String?
  created_at  DateTime            @default(now())
  accountId   Int?
  allocations PaymentAllocation[]
  account     Account?            @relation(fields: [accountId], references: [id])
  party       Party               @relation(fields: [partyId], references: [id])
}

model Account {
  id            Int         @id @default(autoincrement())
  accountHolder String
  bankName      String?
  accountNumber String?
  ifscCode      String?
  branchName    String?
  upiId         String?
  type          AccountType
  createdAt     DateTime    @default(now())
  balance       Decimal     @default(0) @db.Decimal(12, 2)
  paymentsIn    PaymentIn[]
}

model PaymentAllocation {
  id        Int       @id @default(autoincrement())
  paymentId Int
  invoiceId Int
  amount    Decimal   @db.Decimal(12, 2)
  invoice   Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment   PaymentIn @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Invoice {
  id                     Int                       @id @default(autoincrement())
  invoiceNo              String                    @unique
  partyId                Int
  subTotal               Decimal?                  @db.Decimal(12, 2)
  taxAmount              Decimal?                  @db.Decimal(12, 2)
  totalAmount            Decimal                   @db.Decimal(12, 2)
  outstandingAmount      Decimal                   @db.Decimal(12, 2)
  status                 InvoiceStatus             @default(OPEN)
  createdAt              DateTime                  @default(now())
  additionalChargesTotal Decimal?                  @db.Decimal(12, 2)
  applyTcs               Boolean                   @default(false)
  autoRoundOff           Boolean                   @default(false)
  branchCode             String?
  challanNo              String?
  discountAmount         Decimal?                  @db.Decimal(12, 2)
  dueDate                DateTime?
  emailId                String?
  ewayBillNo             String?
  financedBy             String?
  invoiceDate            DateTime                  @default(now())
  notes                  String?
  paymentMode            PaymentMode?
  receivedAmount         Decimal?                  @db.Decimal(12, 2)
  roundOff               Decimal?                  @db.Decimal(12, 2)
  salesman               String?
  taxableAmount          Decimal?                  @db.Decimal(12, 2)
  termsConditions        String?
  updatedAt              DateTime                  @updatedAt
  warrantyPeriod         String?
  quotationId            Int?                      @unique
  showEmptySignatureBox  Boolean                   @default(false)
  signatureUrl           String?
  customFieldValues      Json?                     @default("{}")
  snapshotMetaFields  Json?
  dispatchedThrough      String?
  financeDetails         Json?
  paymentDetails         Json?
  poNumber               String?
  transportName          String?
  vehicleNo              String?
  branch                 Branch?                   @relation(fields: [branchCode], references: [branch_code])
  party                  Party                     @relation(fields: [partyId], references: [id])
  quotation              Quotation?                @relation(fields: [quotationId], references: [id])
  deliveryChallanId      Int?
  deliveryChallan        DeliveryChallan?          @relation(fields: [deliveryChallanId], references: [id])
  proformaSource         ProformaInvoice?
  additionalCharges      InvoiceAdditionalCharge[]
  items                  InvoiceItem[]
  allocations            PaymentAllocation[]
  salesReturns           SalesReturn[]

  @@index([invoiceNo])
  @@index([partyId])
  @@index([invoiceDate])
  @@index([branchCode])
}

model InvoiceDetailsSettings {
  id                    Int      @id @default(autoincrement())
  branchCode            String?
  showChallan           Boolean  @default(true)
  showDispatchedThrough Boolean  @default(false)
  showEmailId           Boolean  @default(true)
  showFinancedBy        Boolean  @default(true)
  showSalesman          Boolean  @default(true)
  showTransportName     Boolean  @default(false)
  showWarranty          Boolean  @default(true)
  showPO                Boolean  @default(false)
  showEwayBill          Boolean  @default(true)
  showVehicle           Boolean  @default(false)
  customFields          Json     @default("[]")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PartyContact {
  id         Int      @id @default(autoincrement())
  partyId    Int
  name       String
  mobile     String
  email      String?
  isPrimary  Boolean  @default(false)
  created_at DateTime @default(now())
  party      Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
}

model PartyAddress {
  id          Int      @id @default(autoincrement())
  partyId     Int
  addressType String
  addressLine String
  city        String
  state       String
  pincode     String
  country     String   @default("India")
  isDefault   Boolean  @default(false)
  created_at  DateTime @default(now())
  party       Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
}

model SalesReturn {
  id           Int               @id @default(autoincrement())
  invoiceId    Int             
  partyId      Int
  totalAmount  Float
  reason       String?
  notes        String?
  returnStatus String            @default("Refunded")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  invoice      Invoice           @relation(fields: [invoiceId], references: [id])
  party        Party             @relation(fields: [partyId], references: [id])
  items        SalesReturnItem[]

  @@index([partyId])
}

model SalesReturnItem {
  id            Int          @id @default(autoincrement())
  salesReturnId Int
  productId     Int
  quantity      Int
  price         Float
  godownId      Int?         // ← which godown stock is returned to

  product       Product      @relation(fields: [productId], references: [id])
  salesReturn   SalesReturn  @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  godown        Godown?      @relation(fields: [godownId], references: [godown_id])
}

model Quotation {
  id                     Int                         @id @default(autoincrement())
  partyId                Int
  validTill              DateTime?
  status                 QuotationStatus             @default(OPEN)
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  additionalChargesTotal Decimal?                    @db.Decimal(12, 2)
  branchCode             String?
  challanNo              String?
  discountAmount         Decimal?                    @db.Decimal(12, 2)
  emailId                String?
  ewayBillNo             String?
  financedBy             String?
  notes                  String?
  quotationDate          DateTime                    @default(now())
  quotationNo            String                      @unique @default(cuid())
  roundOff               Decimal?                    @db.Decimal(12, 2)
  salesman               String?
  subTotal               Decimal?                    @db.Decimal(12, 2)
  taxAmount              Decimal?                    @db.Decimal(12, 2)
  taxableAmount          Decimal?                    @db.Decimal(12, 2)
  termsConditions        String?
  totalAmount            Decimal                     @db.Decimal(12, 2)
  warrantyPeriod         String?
  showEmptySignatureBox  Boolean                     @default(false)
  signatureUrl           String?
  invoices               Invoice?
  branch                 Branch?                     @relation(fields: [branchCode], references: [branch_code])
  party                  Party                       @relation(fields: [partyId], references: [id])
  additionalCharges      QuotationAdditionalCharge[]
  items                  QuotationItem[]

  @@index([partyId])
  @@index([quotationDate])
}

model QuotationItem {
  id          Int       @id @default(autoincrement())
  quotationId Int
  productId   Int
  quantity    Int
  price       Decimal   @db.Decimal(10, 2)
  total       Decimal   @db.Decimal(10, 2)
  discount    Decimal?  @db.Decimal(10, 2)
  taxAmount   Decimal?  @db.Decimal(10, 2)
  taxRate     Float?
  godownId    Int?
  godown      Godown?   @relation(fields: [godownId], references: [godown_id])
  product     Product   @relation(fields: [productId], references: [id])
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@index([productId])
}

model QuotationAdditionalCharge {
  id          Int       @id @default(autoincrement())
  quotationId Int
  name        String
  amount      Decimal   @db.Decimal(10, 2)
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model QuotationSettings {
  id             Int     @id @default(autoincrement())
  prefix         String?
  sequenceNumber Int     @default(1)
  branchCode     String?
  branch         Branch? @relation(fields: [branchCode], references: [branch_code])
}

model InvoiceSettings {
  id                 Int      @id @default(autoincrement())
  prefix             String?
  sequenceNumber     Int      @default(1)
  enablePrefix       Boolean  @default(false)
  showPurchasePrice  Boolean  @default(false)
  showItemImage      Boolean  @default(false)
  enablePriceHistory Boolean  @default(false)
  invoiceTheme       String?  @default("Advanced GST")
  branchCode         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  branch             Branch?  @relation(fields: [branchCode], references: [branch_code])
}

model ProformaInvoice {
  id         Int    @id @default(autoincrement())
  proformaNo String @unique

  // ── Relations (FKs) ──
  partyId       Int
  branchCode    String?
  bankAccountId Int?

  // ── Dates ──
  proformaDate     DateTime  @default(now())
  validTill        DateTime?
  paymentTermsDays Int?

  // ── Extra header fields ──
  ewayBillNo        String?
  challanNo         String?
  financedBy        String?
  salesman          String?
  emailId           String?
  warrantyPeriod    String?
  poNumber          String?
  vehicleNo         String?
  dispatchedThrough String?
  transportName     String?

  // ── Addresses ──
  shippingAddress Json?

  // ── Totals ──
  subTotal               Decimal? @db.Decimal(12, 2)
  taxableAmount          Decimal? @db.Decimal(12, 2)
  discountAmount         Decimal? @db.Decimal(12, 2)
  additionalChargesTotal Decimal? @db.Decimal(12, 2)
  taxAmount              Decimal? @db.Decimal(12, 2)
  roundOff               Decimal? @db.Decimal(12, 2)
  totalAmount            Decimal  @db.Decimal(12, 2)

  // ── Discount / adjustment ──
  discountType String?
  discountPct  Decimal? @default(0) @db.Decimal(5, 2)
  discountAmt  Decimal? @default(0) @db.Decimal(10, 2)
  adjustType   String?
  adjustAmt    Decimal? @default(0) @db.Decimal(10, 2)
  autoRoundOff Boolean  @default(false)

  // ── Notes / terms ──
  notes           String?
  termsConditions String?

  // ── Custom fields ──
  customFieldValues Json?

  // ── Signature ──
  showEmptySignatureBox Boolean @default(false)
  signatureUrl          String?

  // ── Status ──
  status ProformaStatus @default(DRAFT)

  // ── Conversion tracking ──
  convertedToInvoiceId Int?      @unique
  convertedAt          DateTime?

  // ── Timestamps ──
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──
  party            Party             @relation(fields: [partyId], references: [id])
  branch           Branch?           @relation(fields: [branchCode], references: [branch_code])
  convertedInvoice Invoice?          @relation(fields: [convertedToInvoiceId], references: [id])
  bankAccount      PartyBankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  items             ProformaInvoiceItem[]
  additionalCharges ProformaAdditionalCharge[]

  // ── Indexes ──
  @@index([status, branchCode])
  @@index([convertedToInvoiceId])
  @@index([partyId])
  @@index([proformaDate])
}

model ProformaInvoiceItem {
  id          Int      @id @default(autoincrement())
  proformaId  Int
  productId   Int? // nullable — user may type a free-text item
  productName String // always store the display name
  description String?
  hsnSac      String?
  quantity    Decimal  @db.Decimal(10, 3)
  unit        String?  @default("PCS")
  price       Decimal  @db.Decimal(10, 2)
  discountPct Float?   @default(0)
  discountAmt Float?   @default(0)
  taxLabel    String?  @default("None")
  taxRate     Float?   @default(0)
  taxAmount   Decimal? @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  godownId    Int?

  proformaInvoice ProformaInvoice @relation(fields: [proformaId], references: [id], onDelete: Cascade)
  product         Product?        @relation(fields: [productId], references: [id])
  godown          Godown?         @relation(fields: [godownId], references: [godown_id])

  @@index([proformaId])
  @@index([productId])
}

model ProformaAdditionalCharge {
  id         Int      @id @default(autoincrement())
  proformaId Int
  name       String
  amount     Decimal  @db.Decimal(10, 2)
  taxLabel   String?  @default("No Tax Applicable")
  taxAmount  Decimal? @db.Decimal(10, 2)

  proforma ProformaInvoice @relation(fields: [proformaId], references: [id], onDelete: Cascade)
}

model ProformaSettings {
  id             Int      @id @default(autoincrement())
  prefix         String?
  sequenceNumber Int      @default(1)
  enablePrefix   Boolean  @default(false)
  showItemImage  Boolean  @default(false)
  priceHistory   Boolean  @default(false)
  branchCode     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch Branch? @relation(fields: [branchCode], references: [branch_code])
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  productId   Int?     // nullable — user may type a free-text item
  productName String?  // always store the display name for free-text items
  description String?
  itemCode   String?
  hsnCode String?
  
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  discount    Decimal? @db.Decimal(10, 2)
  taxAmount   Decimal? @db.Decimal(10, 2)
  taxRate     Float?
  godownId    Int?
  discountPct Float?
  godown      Godown?  @relation(fields: [godownId], references: [godown_id])
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@index([godownId])
}

model InvoiceAdditionalCharge {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  name      String
  amount    Decimal  @db.Decimal(10, 2)
  taxAmount Decimal? @db.Decimal(10, 2)
  taxLabel  String?  @default("No Tax Applicable")
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model PartyBankAccount {
  id              Int               @id @default(autoincrement())
  partyId         Int
  accountHolder   String
  accountNumber   String
  bankName        String
  ifscCode        String
  branchName      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  upiId           String?
  party           Party             @relation(fields: [partyId], references: [id], onDelete: Cascade)
  ProformaInvoice ProformaInvoice[]

  @@unique([partyId, accountNumber])
  @@index([partyId])
}

model PartyCustomField {
  id         Int      @id @default(autoincrement())
  partyId    Int
  fieldName  String
  fieldValue String
  createdAt  DateTime @default(now())
  party      Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
}

model PurchaseInvoice {
  id                     Int                               @id @default(autoincrement())
  purchaseInvNo          String                            @unique
  originalInvNo          String?
  partyId                Int
  branchCode             String?
  invoiceDate            DateTime                          @default(now())
  dueDate                DateTime?
  ewayBillNo             String?
  challanNo              String?
  financedBy             String?
  salesman               String?
  emailId                String?
  warrantyPeriod         String?
  notes                  String?
  termsConditions        String?
  subTotal               Decimal?                          @db.Decimal(12, 2)
  taxableAmount          Decimal?                          @db.Decimal(12, 2)
  discountAmount         Decimal?                          @db.Decimal(12, 2)
  additionalChargesTotal Decimal?                          @db.Decimal(12, 2)
  taxAmount              Decimal?                          @db.Decimal(12, 2)
  roundOff               Decimal?                          @db.Decimal(12, 2)
  totalAmount            Decimal                           @db.Decimal(12, 2)
  amountPaid             Decimal?                          @db.Decimal(12, 2)
  balanceAmount          Decimal?                          @db.Decimal(12, 2)
  paymentMode            PaymentMode?
  applyTcs               Boolean                           @default(false)
  applyTds               Boolean                           @default(false)
  autoRoundOff           Boolean                           @default(false)
  status                 PurchaseInvoiceStatus             @default(OPEN)
  createdAt              DateTime                          @default(now())
  updatedAt              DateTime                          @updatedAt
  showEmptySignatureBox  Boolean                           @default(false)
  signatureUrl           String?
  paymentOutInvoices     PaymentOutInvoice[]
  branch                 Branch?                           @relation(fields: [branchCode], references: [branch_code])
  party                  Party                             @relation(fields: [partyId], references: [id])
  additionalCharges      PurchaseInvoiceAdditionalCharge[]
  items                  PurchaseInvoiceItem[]

  @@index([partyId])
  @@index([invoiceDate])
  @@index([branchCode])
}

model PurchaseInvoiceItem {
  id                Int             @id @default(autoincrement())
  purchaseInvoiceId Int
  productId         Int
  hsnSac            String?
  quantity          Decimal         @db.Decimal(10, 3)
  price             Decimal         @db.Decimal(10, 2)
  discount          Decimal?        @db.Decimal(10, 2)
  taxRate           Float?
  taxAmount         Decimal?        @db.Decimal(10, 2)
  total             Decimal         @db.Decimal(10, 2)
  godownId          Int?
  godown            Godown?         @relation(fields: [godownId], references: [godown_id])
  product           Product         @relation(fields: [productId], references: [id])
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
}

model PurchaseInvoiceAdditionalCharge {
  id                Int             @id @default(autoincrement())
  purchaseInvoiceId Int
  name              String
  amount            Decimal         @db.Decimal(10, 2)
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
}

model PurchaseInvoiceSettings {
  id                 Int      @id @default(autoincrement())
  prefix             String?
  sequenceNumber     Int      @default(1)
  enablePrefix       Boolean  @default(false)
  branchCode         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  enablePriceHistory Boolean  @default(false)
  purchaseTheme      String?  @default("Advanced GST")
  showItemImage      Boolean  @default(false)
  showPurchasePrice  Boolean  @default(false)
  branch             Branch?  @relation(fields: [branchCode], references: [branch_code])
}

model PaymentOut {
  id            Int                 @id @default(autoincrement())
  paymentNumber String              @unique
  date          DateTime
  partyId       Int
  amountPaid    Decimal             @db.Decimal(12, 2)
  discount      Decimal?            @db.Decimal(12, 2)
  paymentMode   PaymentMode
  notes         String?
  createdAt     DateTime            @default(now())
  party         Party               @relation(fields: [partyId], references: [id])
  invoices      PaymentOutInvoice[]
}

model PaymentOutInvoice {
  id                Int             @id @default(autoincrement())
  paymentOutId      Int
  purchaseInvoiceId Int
  invoiceAmount     Decimal         @db.Decimal(12, 2)
  discount          Decimal?        @db.Decimal(12, 2)
  amountPaid        Decimal         @db.Decimal(12, 2)
  balanceAmount     Decimal         @db.Decimal(12, 2)
  paymentOut        PaymentOut      @relation(fields: [paymentOutId], references: [id])
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])
}

model PaymentOutSettings {
  id             Int      @id @default(autoincrement())
  prefix         String?
  sequenceNumber Int      @default(1)
  enablePrefix   Boolean  @default(false)
  branchCode     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  branch         Branch?  @relation(fields: [branchCode], references: [branch_code])
}

model PurchaseOrder {
  id                     Int                             @id @default(autoincrement())
  poNumber               Int
  partyId                Int
  branchCode             String?
  poDate                 DateTime                        @default(now())
  validTill              DateTime?
  challanNo              String?
  financedBy             String?
  salesman               String?
  emailId                String?
  warrantyPeriod         String?
  notes                  String?
  termsConditions        String?
  subTotal               Decimal?                        @db.Decimal(12, 2)
  taxableAmount          Decimal?                        @db.Decimal(12, 2)
  discountAmount         Decimal?                        @db.Decimal(12, 2)
  additionalChargesTotal Decimal?                        @db.Decimal(12, 2)
  taxAmount              Decimal?                        @db.Decimal(12, 2)
  roundOff               Decimal?                        @db.Decimal(12, 2)
  totalAmount            Decimal                         @db.Decimal(12, 2)
  status                 PurchaseOrderStatus             @default(OPEN)
  createdAt              DateTime                        @default(now())
  updatedAt              DateTime                        @updatedAt
  branch                 Branch?                         @relation(fields: [branchCode], references: [branch_code])
  party                  Party                           @relation(fields: [partyId], references: [id])
  additionalCharges      PurchaseOrderAdditionalCharge[]
  PurchaseOrderHistory   PurchaseOrderHistory[]
  items                  PurchaseOrderItem[]

  @@index([partyId])
  @@index([poDate])
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  productId       Int
  quantity        Decimal       @db.Decimal(10, 3)
  price           Decimal       @db.Decimal(10, 2)
  discount        Decimal?      @db.Decimal(10, 2)
  taxRate         Float?
  taxAmount       Decimal?      @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  hsnSac          String?
  product         Product       @relation(fields: [productId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model PurchaseOrderAdditionalCharge {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  name            String
  amount          Decimal       @db.Decimal(10, 2)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model PurchaseOrderHistory {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  action          String
  description     String?
  createdAt       DateTime      @default(now())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model DeliveryChallan {
  id         Int     @id @default(autoincrement())
  challanNo  String  @unique
  partyId    Int
  branchCode String?

  // ── Header dates ──
  challanDate DateTime @default(now())

  // ── Optional meta fields (mirror Invoice fields) ──
  eWayBillNo        String?
  challanNoRef      String? // "reference challan no" from the form
  financedBy        String?
  salesman          String?
  emailId           String?
  warrantyPeriod    String?
  poNumber          String?
  vehicleNo         String?
  dispatchedThrough String?
  transportName     String?

  // ── Address ──
  shippingAddress String?

  // ── Totals ──
  subTotal               Decimal? @db.Decimal(12, 2)
  taxAmount              Decimal? @db.Decimal(12, 2)
  discountAmount         Decimal? @db.Decimal(12, 2)
  additionalChargesTotal Decimal? @db.Decimal(12, 2)
  roundOff               Decimal? @db.Decimal(12, 2)
  totalAmount            Decimal  @db.Decimal(12, 2)

  // ── Discount settings ──
  discountType String? // "After Tax" | "Before Tax"
  discountPct  Float?  @default(0)
  discountAmt  Float?  @default(0)
  autoRoundOff Boolean @default(false)
  roundOffAmt  Float?  @default(0)

  // ── Custom fields (same pattern as Invoice.customFieldValues) ──
  customFieldValues Json? @default("{}")

  // ── Notes / terms ──
  notes           String?
  termsConditions String?

  // ── Signature ──
  showEmptySignatureBox Boolean @default(false)
  signatureUrl          String?

  // ── Status ──
  status DeliveryChallanStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──
  branch            Branch?                           @relation(fields: [branchCode], references: [branch_code])
  party             Party                             @relation(fields: [partyId], references: [id])
  items             DeliveryChallanItem[]
  additionalCharges DeliveryChallanAdditionalCharge[]
  invoices          Invoice[] // challans converted to invoices

  @@index([partyId])
  @@index([challanDate])
  @@index([branchCode])
  @@index([status])
}

model DeliveryChallanItem {
  id          Int      @id @default(autoincrement())
  challanId   Int
  productId   Int? // nullable – user may type a free-text item
  productName String // always store the display name
  hsnSac      String?
  description String?
  quantity    Decimal  @db.Decimal(10, 3)
  unit        String?  @default("PCS")
  price       Decimal  @db.Decimal(10, 2)
  discountPct Float?   @default(0)
  discountAmt Float?   @default(0)
  taxLabel    String?  @default("None")
  taxRate     Float?   @default(0)
  taxAmount   Decimal? @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  godownId    Int?

  challan DeliveryChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
  godown  Godown?         @relation(fields: [godownId], references: [godown_id])

  @@index([challanId])
  @@index([productId])
}

model DeliveryChallanAdditionalCharge {
  id        Int      @id @default(autoincrement())
  challanId Int
  name      String
  amount    Decimal  @db.Decimal(10, 2)
  taxLabel  String?  @default("No Tax Applicable")
  taxAmount Decimal? @db.Decimal(10, 2)

  challan DeliveryChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
}

model DeliveryChallanSettings {
  id             Int      @id @default(autoincrement())
  prefix         String?
  sequenceNumber Int      @default(1)
  enablePrefix   Boolean  @default(false)
  showItemImage  Boolean  @default(true)
  priceHistory   Boolean  @default(true)
  branchCode     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch Branch? @relation(fields: [branchCode], references: [branch_code])
}

